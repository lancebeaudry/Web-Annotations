# Copy to .env and fill in from your Supabase project (Settings -> API).
# Both values are public-safe; RLS is the security boundary.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Email domain that gates team features (export, resolve/reopen UI)
AVALANCHE_EMAIL_DOMAIN=avalanchegr.com

# --- Admin-only secrets (used by admin/new-site.mjs, NEVER in markup.js) ---
# Service role key: dashboard -> Settings -> API Keys -> service_role
SUPABASE_SERVICE_ROLE_KEY=
# Personal access token: supabase.com -> account menu -> Access Tokens
SUPABASE_ACCESS_TOKEN=
